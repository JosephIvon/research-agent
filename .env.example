# ===========================================
# LLM 提供商配置
# ===========================================
# 选择 LLM 提供商: minimax / deepseek / doubao / glm / openai
LLM_PROVIDER=minimax

# LLM 备用提供商（主提供商熔断后自动降级）
# LLM_FALLBACK_PROVIDER=deepseek

# Minimax（默认）
MINIMAX_API_KEY=YOUR_KEY_HERE
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.5

# DeepSeek
# DEEPSEEK_API_KEY=YOUR_KEY_HERE
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 豆包
# DOUBAO_API_KEY=YOUR_KEY_HERE
# DOUBAO_BASE_URL=https://api.doubao.com
# DOUBAO_MODEL=Doubao-3.5

# 智谱 GLM
# GLM_API_KEY=YOUR_KEY_HERE
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4

# OpenAI
# OPENAI_API_KEY=YOUR_KEY_HERE
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ===========================================
# 搜索配置（默认 SearXNG）
# ===========================================
SEARCH_PROVIDER=searxng
SEARXNG_URL=http://localhost:8888
SEARCH_TIMEOUT=15
SEARCH_MAX_RESULTS=10

# SearXNG Docker 部署密钥（必填）
SEARXNG_SECRET=YOUR_32_CHAR_HEX_SECRET

# 可选降级：Bing HTML 抓取（稳定性一般）
# SEARCH_PROVIDER=bing

# 可选降级：SerpAPI（付费 SaaS）
# SERPAPI_KEY=YOUR_KEY_HERE

# ===========================================
# 飞书文档同步（可选）
# ===========================================
FEISHU_APP_ID=YOUR_FEISHU_APP_ID
FEISHU_APP_SECRET=YOUR_KEY_HERE

# ===========================================
# 腾讯文档同步（可选）
# ===========================================
TENCENT_CLIENT_ID=YOUR_KEY_HERE
TENCENT_APP_SECRET=YOUR_KEY_HERE

# ===========================================
# 运行配置
# ===========================================
MAX_RETRIES=3
TIMEOUT_SECONDS=60
MAX_FETCH_URLS=10
ALLOW_PRIVATE_NETWORK_URLS=false
VERIFICATION_PASS_THRESHOLD=7.0
VERIFICATION_WARN_THRESHOLD=5.0

# ===========================================
# LLM 超时与熔断配置
# ===========================================
LLM_CONNECT_TIMEOUT=10      # 连接超时（秒）
LLM_READ_TIMEOUT=120       # 读取超时（秒）
LLM_RETRY_BACKOFF_MAX=30   # 最大退避时间（秒）
LLM_CIRCUIT_BREAKER_THRESHOLD=5   # 熔断阈值（连续失败次数）
LLM_CIRCUIT_BREAKER_TIMEOUT=60     # 熔断恢复超时（秒）
LLM_RETRY_DELAY=1.0               # 重试初始延迟（秒）
LLM_RETRY_BACKOFF_FACTOR=2        # 重试退避因子
LLM_MAX_CONTENT_CHARS=8000        # LLM 输入内容截断字符数

# ===========================================
# API 服务安全配置
# ===========================================
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8080
API_MAX_BODY_BYTES=1048576
API_AUTH_TOKEN=
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_32_PLUS_CHAR_SECRET
JWT_EXPIRE_MINUTES=1440
ALLOWED_HOSTS=127.0.0.1,localhost,research-agent
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ===========================================
# 速率限制配置
# ===========================================
RATE_LIMIT_PER_IP=60/minute
RATE_LIMIT_PER_TOKEN=120/minute

# ===========================================
# 任务存储配置
# ===========================================
REDIS_URL=redis://localhost:6379/0
TASK_STORE_BACKEND=redis

# ===========================================
# 爬虫与 SSE 配置
# ===========================================
CRAWL_MAX_CONCURRENCY=3          # 爬虫最大并发数
CRAWL_REQUEST_INTERVAL=1.0       # 爬虫请求间隔（秒）
MIN_COMPETITORS_FOR_COMPARISON=2 # 横向对比最少竞品数
SSE_KEEPALIVE_SECONDS=30         # SSE 心跳间隔（秒）

# ===========================================
# Docker 部署配置
# ===========================================
TZ=Asia/Shanghai
