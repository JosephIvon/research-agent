# ===========================================
# LLM 提供商配置
# ===========================================
# 选择 LLM 提供商: minimax / deepseek / doubao / glm / openai
LLM_PROVIDER=minimax

# Minimax（默认）
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.5

# DeepSeek
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 豆包
# DOUBAO_API_KEY=your_doubao_api_key
# DOUBAO_BASE_URL=https://api.doubao.com
# DOUBAO_MODEL=Doubao-3.5

# 智谱 GLM
# GLM_API_KEY=your_glm_api_key
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4

# OpenAI
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ===========================================
# 搜索配置（默认 SearXNG）
# ===========================================
SEARCH_PROVIDER=searxng
SEARXNG_URL=http://localhost:8888
SEARCH_TIMEOUT=15
SEARCH_MAX_RESULTS=10

# SearXNG Docker 部署密钥（必填）
SEARXNG_SECRET=replace_with_32_random_hex_chars

# 可选降级：Bing HTML 抓取（稳定性一般）
# SEARCH_PROVIDER=bing

# 可选降级：SerpAPI（付费 SaaS）
# SERPAPI_KEY=your_serpapi_key

# ===========================================
# 飞书文档同步（可选）
# ===========================================
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# ===========================================
# 腾讯文档同步（可选）
# ===========================================
TENCENT_CLIENT_ID=your_tencent_client_id
TENCENT_APP_SECRET=your_tencent_app_secret

# ===========================================
# 运行配置
# ===========================================
MAX_RETRIES=3
TIMEOUT_SECONDS=60
MAX_FETCH_URLS=10
ALLOW_PRIVATE_NETWORK_URLS=false
VERIFICATION_PASS_THRESHOLD=7.0
VERIFICATION_WARN_THRESHOLD=5.0

# ===========================================
# API 服务安全配置
# ===========================================
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8080
API_MAX_BODY_BYTES=1048576
API_AUTH_TOKEN=
ALLOWED_HOSTS=127.0.0.1,localhost

# ===========================================
# Docker 部署配置
# ===========================================
TZ=Asia/Shanghai